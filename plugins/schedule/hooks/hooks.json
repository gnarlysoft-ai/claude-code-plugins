{
  "description": "Schedule plugin hooks - repeating prompt schedule control via Stop hook",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/schedule-stop-hook.py",
            "timeout": 7200,
            "statusMessage": "Checking schedule..."
          }
        ]
      }
    ]
  }
}
